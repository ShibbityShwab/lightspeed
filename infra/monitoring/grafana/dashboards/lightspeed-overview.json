    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 80 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 21,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Latency Distribution (histogram rate)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(lightspeed_relay_latency_us_bucket{le=\"1\"}[5m])", "legendFormat": "{{ node_id }} ≤1ms", "refId": "A" },
        { "expr": "rate(lightspeed_relay_latency_us_bucket{le=\"10\"}[5m]) - rate(lightspeed_relay_latency_us_bucket{le=\"1\"}[5m])", "legendFormat": "{{ node_id }} 1-10ms", "refId": "B" },
        { "expr": "rate(lightspeed_relay_latency_us_bucket{le=\"50\"}[5m]) - rate(lightspeed_relay_latency_us_bucket{le=\"10\"}[5m])", "legendFormat": "{{ node_id }} 10-50ms", "refId": "C" },
        { "expr": "rate(lightspeed_relay_latency_us_bucket{le=\"250\"}[5m]) - rate(lightspeed_relay_latency_us_bucket{le=\"50\"}[5m])", "legendFormat": "{{ node_id }} 50-250ms", "refId": "D" }
